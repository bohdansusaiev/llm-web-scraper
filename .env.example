DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# OpenAlex requires an email for the polite pool (faster, more reliable).
# https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=you@example.com

# Optional: Semantic Scholar API key (free tier works without one, but rate-limited).
# SEMANTIC_SCHOLAR_API_KEY=

# CORE open access aggregator — 200M+ papers. Get a free key at:
# https://core.ac.uk/services/api
# CORE_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
